###< symfony/asset-mapper ###

# IDE and editor files
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# System files
.DS_Store
Thumbs.db

# SQLite databases - should not be committed for security and consistency
/var/data.db
/var/data_*.db
/var/*.db
*.sqlite
*.sqlite3

# Runtime uploads generated by the app should not be committed.
/public/uploads/characters/*
!/public/uploads/characters/.gitkeep

# Logs and temporary files
*.log
/var/log/*
!/var/log/.gitkeep

# Backup files
*.backup
*.bak
