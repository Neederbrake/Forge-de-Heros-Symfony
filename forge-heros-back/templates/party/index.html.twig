{% extends 'base.html.twig' %}

{% block title %}Party index{% endblock %}

{% block body %}
    <h1>Party index</h1>

    {# filtre les groupes #}
    <div style="background: #f1f1f1; padding: 15px; margin-bottom: 20px; border-radius: 5px;">
        <form method="get" action="{{ path('app_party_index') }}" style="display: flex; gap: 10px; align-items: center;">
            <label for="filter">afficher :</label>
            <select name="filter" id="filter">
                <option value="">-- tous les groupes --</option>
                <option value="available" {% if app.request.query.get('filter') == 'available' %}selected{% endif %}>places disponibles</option>
                <option value="full" {% if app.request.query.get('filter') == 'full' %}selected{% endif %}>groupes complets</option>
            </select>
            <button type="submit">filtrer</button>
            <a href="{{ path('app_party_index') }}" style="margin-left: 10px; text-decoration: none; color: gray;">reinitialiser</a>
        </form>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Description</th>
                <th>MaxSize</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for party in parties %}
            <tr>
                <td>{{ party.id }}</td>
                <td>{{ party.name }}</td>
                <td>{{ party.description }}</td>
                <td>{{ party.maxSize }}</td>
                <td>
                    <a href="{{ path('app_party_show', {'id': party.id}) }}">show</a>

                    {# on cache le bouton edit pour les autres #}
                    {% if party.creator == app.user or is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_party_edit', {'id': party.id}) }}">edit</a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_party_new') }}">Create new</a>
{% endblock %}
