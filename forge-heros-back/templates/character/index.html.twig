{% extends 'base.html.twig' %}

{% block title %}Character index{% endblock %}

{% block body %}
    <h1>Character index</h1>

    {# formulaire de recherche en methode get #}
    <div class="filter-panel">
        <form method="get" action="{{ path('app_character_index') }}" class="filter-row">

            {# champ de texte pour le nom #}
            <input type="text" name="search" placeholder="chercher un nom..." value="{{ app.request.query.get('search') }}">

            {# menu deroulant des races #}
            <select name="race">
                <option value="">-- toutes les races --</option>
                {% for race in races %}
                    <option value="{{ race.id }}" {% if app.request.query.get('race') == race.id %}selected{% endif %}>
                        {{ race.name }}
                    </option>
                {% endfor %}
            </select>

            {# menu deroulant des classes #}
            <select name="class">
                <option value="">-- toutes les classes --</option>
                {% for class in classes %}
                    <option value="{{ class.id }}" {% if app.request.query.get('class') == class.id %}selected{% endif %}>
                        {{ class.name }}
                    </option>
                {% endfor %}
            </select>

            {# boutons d action #}
            <button type="submit">filtrer</button>
            <a href="{{ path('app_character_index') }}" class="muted-link">reinitialiser</a>
        </form>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Level</th>
                <th>Strength</th>
                <th>Dexterity</th>
                <th>Constitution</th>
                <th>Intelligence</th>
                <th>Wisdom</th>
                <th>Charisma</th>
                <th>HealthPoints</th>
                <th>Race</th>
                <th>Class</th>
                <th>Image</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for character in characters %}
            <tr>
                <td>{{ character.id }}</td>
                <td>{{ character.name }}</td>
                <td>{{ character.level }}</td>
                <td>{{ character.strength }}</td>
                <td>{{ character.dexterity }}</td>
                <td>{{ character.constitution }}</td>
                <td>{{ character.intelligence }}</td>
                <td>{{ character.wisdom }}</td>
                <td>{{ character.charisma }}</td>
                <td>{{ character.healthPoints }}</td>
                <td>{{ character.race.name }}</td>
                <td>{{ character.characterClass.name }}</td>
                <td>{{ character.image }}</td>
                <td>
                    <a href="{{ path('app_character_show', {'id': character.id}) }}">show</a>
                    <a href="{{ path('app_character_edit', {'id': character.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="12">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_character_new') }}">Create new</a>
{% endblock %}
