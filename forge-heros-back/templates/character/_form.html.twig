{{ form_start(form) }}

    {# la ligne magique qui va nous dire ce qui bloque en secret #}
<div style="color: red; font-weight: bold; margin-bottom: 10px;">
    {{ form_errors(form) }}
</div>

{{ form_widget(form) }}

<button class="btn">{{ button_label|default('save') }}</button>

<div style="margin-top: 20px; padding: 15px; background-color: #f8f9fa; border: 2px solid #ccc;">
    <h3 style="margin-top: 0;">compteur de points (point buy)</h3>
    <p>rappel : stats entre 8 et 15. cout total : 27 points.</p>
    <p style="font-size: 1.2em; font-weight: bold;">
        total utilise : <span id="point-counter">0</span> / 27
    </p>
</div>

<script>
    // attend chargement page
    document.addEventListener('DOMContentLoaded', function() {

        // noms generes par symfony
        const statNames = [
            'character[strength]',
            'character[dexterity]',
            'character[constitution]',
            'character[intelligence]',
            'character[wisdom]',
            'character[charisma]'
        ];

        // recupere zone affichage
        const counterDisplay = document.getElementById('point-counter');

        // fonction de calcul
        function updatePoints() {
            let total = 0;

            // boucle sur les stats
            statNames.forEach(function(name) {
                // cherche champ par son attribut name
                const input = document.querySelector('[name="' + name + '"]');
                if (input) {
                    let val = parseInt(input.value);

                    // securite si vide
                    if (isNaN(val)) val = 8;

                    // ajoute points depenses
                    if (val > 8) {
                        total += (val - 8);
                    }
                }
            });

            // met a jour texte
            counterDisplay.innerText = total;

            // change couleur
            if (total === 27) {
                counterDisplay.style.color = 'green';
            } else if (total > 27) {
                counterDisplay.style.color = 'red';
            } else {
                counterDisplay.style.color = 'black';
            }
        }

        // ecoute clavier
        statNames.forEach(function(name) {
            const input = document.querySelector('[name="' + name + '"]');
            if (input) {
                input.addEventListener('input', updatePoints);
            }
        });

        // calcul initial
        updatePoints();
    });
</script>
{{ form_end(form) }}
