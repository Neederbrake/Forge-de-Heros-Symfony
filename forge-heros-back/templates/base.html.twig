<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}welcome!{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
{# menu de navigation global #}
<nav class="site-nav">
    <div class="site-nav-links">
    {# lien accueil pour tous #}
    <a href="/" class="site-nav-link">accueil</a>

    {# menu pour les joueurs connectes #}
    {% if app.user %}

        <a href="{{ path('app_character_index') }}" class="site-nav-link">mes heros</a>
        {# bouton creer heros #}
        <a href="{{ path('app_character_new') }}" class="site-nav-link site-nav-link-cta">+ creer heros</a>

        <a href="{{ path('app_party_index') }}" class="site-nav-link">mes groupes</a>
        {# bouton creer groupe #}
        <a href="{{ path('app_party_new') }}" class="site-nav-link site-nav-link-cta">+ creer groupe</a>

        {# menu special admin #}
        {% if is_granted('ROLE_ADMIN') %}
            <span class="site-nav-separator">admin :</span>
            <div class="site-nav-admin-group">
                <a href="{{ path('app_race_index') }}" class="site-nav-link">races</a>
                <a href="{{ path('app_skill_index') }}" class="site-nav-link">competences</a>
                <a href="{{ path('app_character_class_index') }}" class="site-nav-link">classes</a>
            </div>
        {% endif %}
    </div>

        {# infos joueur et deconnexion #}
        <div class="site-nav-user">
            <span class="site-nav-user-id">joueur : {{ app.user.userIdentifier }}</span>
            <a href="{{ path('app_logout') }}" class="site-nav-link">deconnexion</a>
        </div>

        {# menu pour les non connectes #}
    {% else %}
    </div>
        <div class="site-nav-user">
            <a href="{{ path('app_login') }}" class="site-nav-link">connexion</a>
            <a href="{{ path('app_register') }}" class="site-nav-link">inscription</a>
        </div>
    {% endif %}
</nav>

{# contenu des autres pages #}
<main class="page-shell">

    {# boucle pour afficher les messages d erreur au dessus du contenu #}
    {% for message in app.flashes('error') %}
        <div class="flash-message flash-message-error">
            {{ message }}
        </div>
    {% endfor %}

    {# boucle pour afficher les alertes du serveur #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash-message {% if label == 'error' %}flash-message-error{% else %}flash-message-success{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# le contenu de la page vient se mettre juste en dessous #}
    {% block body %}{% endblock %}
</main>
</body>
</html>