<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}welcome!{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
{# menu de navigation global #}
<nav style="padding: 10px; background: #eee; margin-bottom: 20px;">
    <a href="{{ path('app_home') }}">accueil</a> |

    {# si utilisateur connecte #}
    {% if app.user %}
        <span>bonjour {{ app.user.username }} !</span> |
        <a href="{{ path('app_logout') }}">se deconnecter</a>

        {# menu specifique admin #}
        {% if is_granted('ROLE_ADMIN') %}
            <br><br>
            <strong>administration :</strong>
            <a href="{{ path('app_race_index') }}">races</a> |
            <a href="{{ path('app_character_class_index') }}">classes</a> |
            <a href="{{ path('app_skill_index') }}">competences</a> |
            <a href="{{ path('app_admin_user_index') }}">joueurs</a>
        {% endif %}

        {# si visiteur non connecte #}
    {% else %}
        <a href="{{ path('app_login') }}">se connecter</a> |
        <a href="{{ path('app_register') }}">s inscrire</a>
    {% endif %}
</nav>

{# contenu des autres pages #}
<div style="padding: 20px;">

    {# boucle pour afficher les messages d erreur au dessus du contenu #}
    {% for message in app.flashes('error') %}
        <div style="color: red; font-weight: bold; padding: 10px; border: 2px solid red; margin-bottom: 15px;">
            {{ message }}
        </div>
    {% endfor %}

    {# le contenu de la page vient se mettre juste en dessous #}
    {% block body %}{% endblock %}
</div>
</body>
</html>