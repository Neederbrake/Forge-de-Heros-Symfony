<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}welcome!{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
{# menu de navigation global #}
<nav style="display: flex; gap: 15px; align-items: center; padding: 10px; background: #f0f0f0;">
    {# lien accueil pour tous #}
    <a href="/">accueil</a>

    {# menu pour les joueurs connectes #}
    {% if app.user %}

        <a href="{{ path('app_character_index') }}">mes heros</a>
        {# bouton creer heros #}
        <a href="{{ path('app_character_new') }}" style="background: #4caf50; color: white; padding: 5px 10px; text-decoration: none; border-radius: 5px;">+ creer heros</a>

        <a href="{{ path('app_party_index') }}">mes groupes</a>
        {# bouton creer groupe #}
        <a href="{{ path('app_party_new') }}" style="background: #008cba; color: white; padding: 5px 10px; text-decoration: none; border-radius: 5px;">+ creer groupe</a>

        {# menu special admin #}
        {% if is_granted('ROLE_ADMIN') %}
            <span style="border-left: 1px solid #ccc; padding-left: 15px;">admin :</span>
            <a href="{{ path('app_race_index') }}">races</a>
            <a href="{{ path('app_character_class_index') }}">classes</a>
            <a href="{{ path('app_skill_index') }}">competences</a>
        {% endif %}

        {# infos joueur et deconnexion #}
        <span style="margin-left: auto;">joueur : {{ app.user.userIdentifier }}</span>
        <a href="{{ path('app_logout') }}">deconnexion</a>

        {# menu pour les non connectes #}
    {% else %}
        <span style="margin-left: auto;">
            <a href="{{ path('app_login') }}">connexion</a>
            <a href="{{ path('app_register') }}">inscription</a>
        </span>
    {% endif %}
</nav>

{# contenu des autres pages #}
<div style="padding: 20px;">

    {# boucle pour afficher les messages d erreur au dessus du contenu #}
    {% for message in app.flashes('error') %}
        <div style="color: red; font-weight: bold; padding: 10px; border: 2px solid red; margin-bottom: 15px;">
            {{ message }}
        </div>
    {% endfor %}

    {# boucle pour afficher les alertes du serveur #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div style="padding: 15px; margin-bottom: 20px; border: 2px solid {% if label == 'error' %}red{% else %}green{% endif %}; background-color: {% if label == 'error' %}#fee{% else %}#efe{% endif %}; font-weight: bold; text-align: center;">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# le contenu de la page vient se mettre juste en dessous #}
    {% block body %}{% endblock %}
</div>
</body>
</html>