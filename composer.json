{
    "require": {
        "symfony/framework-bundle": "^8.0",
        "symfony/flex": "^2.10",
        "symfony/runtime": "^8.0",
        "symfony/yaml": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/webapp-pack": "*"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        }
    }
}
